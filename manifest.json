{
  "manifest_version": 3,
  "name": "LiveDevMode (LVDM)",
  "short_name": "LVDM",
  "version": "1.0.0",
  "description": "DevTools-style inspector overlay for any website",
  "icons": {
    "16": "icons/logo.png",
    "32": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "LVDM"
  },
  "commands": {
    "toggle-dev-mode": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Toggle LiveDevMode"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils.js", "overlay.js", "content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ]
}